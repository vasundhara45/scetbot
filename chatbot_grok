import os
from langchain_community.document_loaders import WebBaseLoader
from langchain_text_splitters import RecursiveCharacterTextSplitter
from langchain_huggingface import HuggingFaceEmbeddings
from langchain_community.vectorstores import FAISS
from langchain_classic.chains import RetrievalQA
from langchain_core.prompts import PromptTemplate
import gradio as gr

# ── Step 1: Expanded URLs – All Departments + Key Pages + Sample Faculty ──
# ── Load URLs from scet_all_pages.txt (one URL per line) ──
urls = []

try:
    with open("scet_all_pages.txt", "r", encoding="utf-8") as f:
        for line in f:
            cleaned = line.strip()
            if cleaned and cleaned.startswith("https://scet.ac.in/"):  # only valid SCET URLs
                urls.append(cleaned)
    print(f"Loaded {len(urls)} URLs from scet_all_pages.txt")
except FileNotFoundError:
    print("Warning: scet_all_pages.txt not found → falling back to hardcoded list")
# Deduplicate and sort (in case crawler had repeats)
urls = sorted(set(urls))

# Optional: Limit to max 150-200 pages to avoid memory/time issues
if len(urls) > 200:
    print(f"Limiting to first 200 URLs for performance")
    urls = urls[:200]

print(f"Final number of URLs to index: {len(urls)}")

# ── Step 2: Load documents with error handling ──
print("Loading pages from all departments and key faculty... (may take 2–4 minutes)")
from langchain_community.document_loaders import PyPDFLoader  # add this import

docs = []
for url in urls:
    try:
        if url.lower().endswith(".pdf"):
            loader = PyPDFLoader(url)
        else:
            loader = WebBaseLoader(url)
        loaded = loader.load()
        for doc in loaded:
            doc.metadata["source"] = url
        docs.extend(loaded)
        print(f"Success: {url} ({len(loaded)} items)")
    except Exception as e:
        print(f"Skipped {url}: {str(e)[:100]}...")

if not docs:
    print("No content loaded – check internet or URLs.")
    exit()

# ── Step 3: Chunk & Embed ──
from langchain_text_splitters import RecursiveCharacterTextSplitter

text_splitter = RecursiveCharacterTextSplitter(
    chunk_size=800,
    chunk_overlap=150,
    length_function=len,
)
chunks = text_splitter.split_documents(docs)

print(f"Total chunks: {len(chunks)}")

embeddings = HuggingFaceEmbeddings(model_name="sentence-transformers/all-MiniLM-L6-v2")
vectorstore = FAISS.from_documents(chunks, embeddings)
vectorstore.save_local("scet_full_index")
print("Index saved → scet_full_index/")

