# Custom prompt – now covers all depts/faculty
prompt_template = """You are an official helpful assistant for Sarvajanik College of Engineering & Technology (SCET), Surat.
Answer using ONLY the provided context from the SCET website. Be accurate, polite, and comprehensive.
Cover queries about ANY department (Computer, IT, ECE, Electrical, Mechanical, Civil, Textile, MCA, Applied Sciences, etc.), programs, faculty, placements, etc.
If about a specific department or faculty, mention relevant details.
Include source URLs for transparency.

Context: {context}

Question: {question}

Answer:"""
PROMPT = PromptTemplate(template=prompt_template, input_variables=["context", "question"])

qa_chain = RetrievalQA.from_chain_type(
    llm=llm,
    chain_type="stuff",
    retriever=vectorstore.as_retriever(search_kwargs={"k": 5}),  # More context for broader coverage
    return_source_documents=True,
    chain_type_kwargs={"prompt": PROMPT}
)

# ── Step 5: Answer function with sources ──
# Add these imports at the top if not already there
import datetime

# Inside def answer_question(query):
def answer_question(query):
    result = qa_chain.invoke({"query": query})
    answer = result["result"].strip()

    sources = list(set(doc.metadata["source"] for doc in result["source_documents"]))

    response = f"{answer}\n\n**Sources:**\n" + "\n".join(f"- {s}" for s in sources if s)

    # ── Log if the answer looks unhelpful ──
    low_quality_indicators = [
        "sorry", "don't know", "not found", "cannot answer", "no information",
        "not available", "unable to", ""  # empty answer
    ]

    answer_lower = answer.lower()
    if len(answer) < 30 or any(ind in answer_lower for ind in low_quality_indicators):
        timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        log_entry = f"[{timestamp}] Question: {query}\nAnswer (weak): {answer}\nSources: {sources}\n{'-'*80}\n"

        with open("unanswered_questions.log", "a", encoding="utf-8") as f:
            f.write(log_entry)

        print(f"Logged weak answer: {query[:60]}...")  # console feedback

    return response

# ── Step 6: Gradio UI ──
def chatbot_fn(message, history):
    if not message.strip():
        return history, ""
    resp = answer_question(message)
    history.append((message, resp))
    return history, ""

with gr.Blocks(title="SCET Full Chatbot – All Departments & Faculty") as demo:
    gr.Markdown("""
    # SCET Surat – College Chatbot (All Departments)
    Ask about **any department**, programs, faculty, placements, syllabus, admissions, etc.
    Powered by content from scet.ac.in
    """)
    chat = gr.Chatbot(height=600)
    msg = gr.Textbox(placeholder="Example: Tell me about the Mechanical Engineering department")
    clear_btn = gr.Button("Clear")

    msg.submit(chatbot_fn, [msg, chat], [chat, msg])
    clear_btn.click(lambda: None, None, chat, queue=False)

if __name__ == "__main__":
    print("\nStarting SCET Chatbot... Open the link.")
    demo.launch(share=True)  # Public temp link for testing



